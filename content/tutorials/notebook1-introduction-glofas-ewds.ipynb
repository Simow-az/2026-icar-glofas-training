    "---\n",
    "## Step 9 – (Alternative) Downloading with cdsapi\n",
    "\n",
    "If you prefer a more explicit download workflow, you can use the `cdsapi` package directly. This downloads data to a local NetCDF file, which you can then open with xarray.\n",
    "\n",
    "The `cdsapi` approach is useful when:\n",
    "- You want to cache large datasets on disk\n",
    "- You are running automated scripts in a pipeline\n",
    "- You need very fine control over file naming"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import cdsapi\n",
    "\n",
    "# ─────────────────────────────────────────────────────────────────\n",
    "# Same request as before, but saved to a local file\n",
    "# ─────────────────────────────────────────────────────────────────\n",
    "output_filename = \"glofas_reanalysis_south_asia_2000_2005.nc\"\n",
    "\n",
    "# Only download if the file does not already exist\n",
    "if not os.path.exists(output_filename):\n",
    "    print(f\"Downloading to {output_filename} ...\")\n",
    "    client = cdsapi.Client()\n",
    "    client.retrieve(\n",
    "        \"cems-glofas-reanalysis\",\n",
    "        {\n",
    "            \"system_version\": \"version_4_0\",\n",
    "            \"hydrological_model\": \"lisflood\",\n",
    "            \"product_type\": \"consolidated\",\n",
    "            \"variable\": \"river_discharge_in_the_last_24_hours\",\n",
    "            \"year\": [str(y) for y in range(2000, 2006)],\n",
    "            \"month\": [f\"{m:02d}\" for m in range(1, 13)],\n",
    "            \"day\": [\"01\"],\n",
    "            \"data_format\": \"netcdf4\",\n",
    "            \"download_format\": \"unarchived\",\n",
    "            \"area\": [35, 65, 10, 98],\n",
    "        },\n",
    "    ).download(output_filename)\n",
    "    print(\"Download complete!\")\n",
    "else:\n",
    "    print(f\"File already exists: {output_filename}\")\n",
    "\n",
    "# Open the downloaded file with xarray\n",
    "ds_from_file = xr.open_dataset(output_filename)\n",
    "print(ds_from_file)"
   ]
  },
